{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/core/**",
              "components/feedback/**",
              "components/observatory/**",
              "ui_kits/_shell/**",
              "ui_kits/organism-view/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='TickerEvent'] > JSXAttribute > JSXIdentifier[name!=/^(?:sequence|type|actor|phrase|label|occurredAt|key|ref|className|style|children)$/]",
        "message": "<TickerEvent> doesn't accept that prop. Declared props: sequence, type, actor, phrase, label, occurredAt."
      },
      {
        "selector": "JSXOpeningElement[name.name='AgenomeSummary'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|status|parentIds|spawnBudget|key|ref|className|style|children)$/]",
        "message": "<AgenomeSummary> doesn't accept that prop. Declared props: id, status, parentIds, spawnBudget."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|glyph|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, glyph, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CandidateSummary'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|subtype|title|summary|status|agenomeId|key|ref|className|style|children)$/]",
        "message": "<CandidateSummary> doesn't accept that prop. Declared props: id, subtype, title, summary, status, agenomeId."
      },
      {
        "selector": "JSXOpeningElement[name.name='CandidateSummary'] > JSXAttribute[name.name='subtype'] > Literal[value!=/^(?:cross_domain_transfer|zeitgeist_synthesis)$/]",
        "message": "<CandidateSummary> subtype must be one of 'cross_domain_transfer' | 'zeitgeist_synthesis'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CriticReviewRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:mandate|score|confidence|critique|evidenceRefs|key|ref|className|style|children)$/]",
        "message": "<CriticReviewRow> doesn't accept that prop. Declared props: mandate, score, confidence, critique, evidenceRefs."
      },
      {
        "selector": "JSXOpeningElement[name.name='CriticReviewRow'] > JSXAttribute[name.name='mandate'] > Literal[value!=/^(?:factual_grounding|novelty_prior_art|feasibility|falsification|subtype_specific)$/]",
        "message": "<CriticReviewRow> mandate must be one of 'factual_grounding' | 'novelty_prior_art' | 'feasibility' | 'falsification' | 'subtype_specific'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HealthSummary'] > JSXAttribute > JSXIdentifier[name!=/^(?:currentGeneration|candidatesInFlight|lastEventAgeMs|capsConsumed|key|ref|className|style|children)$/]",
        "message": "<HealthSummary> doesn't accept that prop. Declared props: currentGeneration, candidatesInFlight, lastEventAgeMs, capsConsumed."
      },
      {
        "selector": "JSXOpeningElement[name.name='Meter'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|kind|label|valueLabel|showValue|degraded|height|style|key|ref|className|style|children)$/]",
        "message": "<Meter> doesn't accept that prop. Declared props: value, kind, label, valueLabel, showValue, degraded, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Meter'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:fitness|novelty|energy)$/]",
        "message": "<Meter> kind must be one of 'fitness' | 'novelty' | 'energy'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModeBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:mode|generationLabel|recordedAt|fullWidth|key|ref|className|style|children)$/]",
        "message": "<ModeBanner> doesn't accept that prop. Declared props: mode, generationLabel, recordedAt, fullWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModeBanner'] > JSXAttribute[name.name='mode'] > Literal[value!=/^(?:live|replay|complete|stopped|failed)$/]",
        "message": "<ModeBanner> mode must be one of 'live' | 'replay' | 'complete' | 'stopped' | 'failed'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RunEnergyGauge'] > JSXAttribute > JSXIdentifier[name!=/^(?:spent|budget|mode|showLabel|unit|key|ref|className|style|children)$/]",
        "message": "<RunEnergyGauge> doesn't accept that prop. Declared props: spent, budget, mode, showLabel, unit."
      },
      {
        "selector": "JSXOpeningElement[name.name='RunEnergyGauge'] > JSXAttribute[name.name='mode'] > Literal[value!=/^(?:live|replay)$/]",
        "message": "<RunEnergyGauge> mode must be one of 'live' | 'replay'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:domain|status|size|showLabel|pulse|reason|key|ref|className|style|children)$/]",
        "message": "<StatusBadge> doesn't accept that prop. Declared props: domain, status, size, showLabel, pulse, reason."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<StatusBadge> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|action|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, description, action."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
