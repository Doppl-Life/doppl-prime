{
  "name": "@doppl/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:smoke:web-api": "DOPPL_WEB_API_SMOKE=1 vitest run --config vitest.smoke.config.ts",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@doppl/contracts": "workspace:*",
    "@xyflow/react": "^12.11.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testcontainers/postgresql": "^12.0.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.13.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^10.5.0",
    "happy-dom": "^20.0.0",
    "prettier": "^3.8.4",
    "typescript": "~6.0.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.9"
  }
}
