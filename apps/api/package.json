{
  "name": "@doppl/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./event-store": {
      "types": "./src/event-store/index.ts",
      "default": "./src/event-store/index.ts"
    },
    "./model-gateway": {
      "types": "./src/model-gateway/index.ts",
      "default": "./src/model-gateway/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:int": "vitest run __integration_tests__",
    "test:live": "vitest run __integration_tests__/live",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/event-store/migrate.ts"
  },
  "dependencies": {
    "@doppl/contracts": "workspace:*",
    "drizzle-orm": "0.36.4",
    "langfuse": "3.37.3",
    "openai": "4.77.0",
    "pg": "8.13.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "10.16.0",
    "@types/node": "22.10.2",
    "@types/pg": "8.11.10",
    "drizzle-kit": "0.28.1",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.5"
  }
}
