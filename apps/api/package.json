{
  "name": "@doppl/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.ts --passWithNoTests",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@doppl/contracts": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "openai": "^6.44.0",
    "pg": "^8.22.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.3",
    "@types/node": "^22.13.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  }
}
