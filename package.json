{
  "name": "doppl-prime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit -p tsconfig.base.json && pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:int": "pnpm -r --if-present test:int",
    "test:live": "DOPPL_LIVE_TESTS=1 pnpm -r --if-present test:live"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "typescript": "5.6.3",
    "vitest": "2.1.5"
  }
}
