{
  "name": "doppl-prime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --experimental-strip-types --test 'test/kernel/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/kernel/**/*.ts'",
    "build": "pnpm run typecheck && pnpm run lint && pnpm test && pnpm run web:build",
    "kernel:run": "node --experimental-strip-types src/kernel/cli.ts",
    "kernel:serve": "node --experimental-strip-types src/kernel/server/server.ts",
    "kernel:publish": "node --experimental-strip-types src/kernel/sink/publish-cli.ts",
    "web:build": "vite build --config web/vite.config.js",
    "prestart": "pnpm run web:build",
    "start": "pnpm run kernel:serve"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@xyflow/react": "^12.11.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.0",
    "vite": "^8.0.16",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
