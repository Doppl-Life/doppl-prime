# doppl-prime environment — copy to .env (gitignored). Loaded by `pnpm kernel:serve`.
# The kernel has no fabricated generation: a run is a live model call or a replay of recorded calls.

# Live generation provider. Local-first: leave unset to default to keyless local Ollama when no
# OPENROUTER_API_KEY is present (free, no key). Set explicitly to override.
#   ollama | lmstudio (keyless, local) · openrouter | groq | openai (hosted, need a key)
# DOPPL_LIVE_PROVIDER=ollama

# Default model for the live provider when a request does not pin one.
#   local example: qwen3.6:35b-a3b (reliable JSON) or gemma4:e4b (faster)
#   hosted example: openai/gpt-4.1-mini
# DOPPL_LIVE_MODEL=qwen3.6:35b-a3b

# Hosted provider keys (only needed for hosted providers; local needs none).
# OPENROUTER_API_KEY=
# GROQ_API_KEY=
# OPENAI_API_KEY=

# Hosted live generation from the dashboard is gated (cost/secret control). A keyless local model
# skips these gates. For a hosted public demo, enable explicitly:
# DOPPL_ENABLE_LIVE_LLM=true
# DOPPL_REQUIRE_LIVE_DEMO_TOKEN=true
# DOPPL_LIVE_DEMO_TOKEN=

# Server API key (optional): when set, /kernel/runs requires a Bearer token; dashboard routes stay open.
# KERNEL_API_KEY=
