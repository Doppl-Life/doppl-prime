# Doppl kernel — environment template. Copy to .env and fill in only the keys you use.
# The kernel reads these for HTTP model providers (--live-model --provider <name>).
# CLI providers (--cli claude|grok|gemini|codex) use their own CLI login, not these keys.
# Local providers (ollama, lmstudio) need no key at all.

# OpenRouter — default hosted provider (--provider openrouter)
OPENROUTER_API_KEY=

# Groq — fast hosted inference (--provider groq)
GROQ_API_KEY=

# OpenAI — hosted (--provider openai)
OPENAI_API_KEY=

# Anthropic — not read by the kernel; the `claude` CLI uses its own login. Set only if other
# tooling needs it.
ANTHROPIC_API_KEY=
