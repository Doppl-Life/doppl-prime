# Doppl environment variables — copy to .env (gitignored) and fill in.
# All values are read at boot via packages/contracts/src/config/validate.ts (defaults < file < env precedence).

# ---- Provider keys (required at runtime; Phase 2) ----
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=

# ---- Database (Phase 1) ----
# Defaults below match docker-compose.yml at the repo root.
# `docker compose up -d postgres` brings up the local instance.
DATABASE_URL=postgres://doppl:doppl@localhost:5434/doppl_dev

# ---- Observability (Phase 2) ----
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# ---- Run defaults (overrides Phase 0 RunConfig defaults) ----
# DOPPL_MAX_POPULATION=
# DOPPL_MAX_GENERATIONS=
# DOPPL_ENERGY_BUDGET=
# DOPPL_RNG_SEED=
