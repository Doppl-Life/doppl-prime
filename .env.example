# Doppl — demo environment reference.
#
# Copy to `.env` and fill in the REQUIRED values. This file is SINGLE-SOURCED from the boot env
# allowlist in code (REQUIRED_CREDENTIAL_ENV · ENV_ALLOWLIST · main.ts boot vars) and pinned by the
# drift-guard test `apps/api/test/unit/config/env-example-drift.test.ts` — so it can't silently drift
# from what boot actually reads. PLACEHOLDERS ONLY — never commit a real secret (KEY SAFETY RULE #4).
#
# (Langfuse is intentionally absent — it's non-authoritative and not yet wired into boot; it adds no
#  required env. See DEMO_RUNBOOK.md.)

# --- REQUIRED credentials (fail-fast at boot; assertProviderCredentials) -------------------------
OPENROUTER_API_KEY=REPLACE_ME                            # REQUIRED — generation/critic/judge/fusion via the live gateway
OPENAI_API_KEY=REPLACE_ME                                # REQUIRED — embeddings/novelty (direct OpenAI)
DATABASE_URL=postgres://doppl:REPLACE_ME@localhost:5432/doppl  # REQUIRED — Postgres event store (append-only run_events)

# --- OPTIONAL kernel caps + RNG (closed ENV_ALLOWLIST → caps/runConfig) --------------------------
# Caps are sized for a MULTI-TURN tool-use research run (each agenome researches via web/X/YouTube →
# several LLM round-trips + tool calls per candidate). The kernel enforces these (rule #1).
DOPPL_MAX_POPULATION=12                                  # OPTIONAL — cap: max candidates per generation (default 12)
DOPPL_MAX_GENERATIONS=6                                  # OPTIONAL — cap: max generations (default 6)
DOPPL_ENERGY_BUDGET=12000                                # OPTIONAL — cap: doppl_energy budget (default 12000)
DOPPL_MAX_TOOL_CALLS=600                                 # OPTIONAL — cap: total agent research tool calls per run (default 600)
DOPPL_WALL_CLOCK_MS=1200000                              # OPTIONAL — cap: run wall-clock timeout in ms (default 1200000 = 20 min)
DOPPL_RNG_SEED=42                                        # OPTIONAL — deterministic RNG seed (default 42)

# --- OPTIONAL boot orchestration (main.ts) ------------------------------------------------------
DOPPL_GATEWAY=recorded                                   # OPTIONAL — recorded (default) | live (real LLMs; needs the keys above)
DOPPL_SEED_FIXTURE=demo-recorded-001                     # OPTIONAL — seed a committed replay fixture (creds-free demo); absent → live forward boot
# DOPPL_FIXTURE_DIR — intentionally OMITTED (PD.19): a RELATIVE value breaks `pnpm -C apps/api start`
#   (CWD=apps/api → ENOENT). The code default is module-relative (repo fixtures/replay/), correct from
#   any CWD — leave it unset. Set an ABSOLUTE path only to override the committed fixtures location.
HOST=0.0.0.0                                             # OPTIONAL — listen host (default 0.0.0.0)
PORT=3000                                                # OPTIONAL — listen port (default 3000)
