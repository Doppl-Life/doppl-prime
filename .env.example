# Doppl environment variables — copy to .env (gitignored) and fill in.
# All values are read at boot via packages/contracts/src/config/validate.ts (defaults < file < env precedence).

# ---- Provider keys (required at runtime; Phase 2) ----
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=

# ---- Database (Phase 1) ----
# DATABASE_URL=postgresql://localhost:5432/doppl

# ---- Observability (Phase 2) ----
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# ---- Run defaults (overrides Phase 0 RunConfig defaults) ----
# DOPPL_MAX_POPULATION=
# DOPPL_MAX_GENERATIONS=
# DOPPL_ENERGY_BUDGET=
# DOPPL_RNG_SEED=
