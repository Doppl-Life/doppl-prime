{
  "name": "doppl-calibrator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run --environment jsdom",
    "test:watch": "vitest",
    "generate:index": "tsx src/server/generateIndex.ts",
    "import:solutions": "tsx src/server/importers/importSolutions.ts",
    "import:kernel-runs": "tsx src/server/importers/importKernelRuns.ts",
    "serve:ratings": "tsx src/server/hostedAgardenRatingServer.ts",
    "start": "npm run serve:ratings",
    "export:static": "npm run generate:index && npm run build && tsx src/server/exportStatic.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "gray-matter": "^4.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
